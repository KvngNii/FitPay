# Public (client-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose)
SUPABASE_SERVICE_ROLE_KEY=

# Moolre Live (flip USE_SANDBOX=false for demo/production)
MOOLRE_API_USER=
MOOLRE_API_KEY=
MOOLRE_API_PUBKEY=
MOOLRE_VAS_KEY=

# Moolre Sandbox
MOOLRE_SANDBOX_API_USER=
MOOLRE_SANDBOX_API_KEY=
MOOLRE_SANDBOX_API_PUBKEY=
MOOLRE_SANDBOX_VAS_KEY=

# Moolre Shared
MOOLRE_ACCOUNT_NUMBER=
MOOLRE_WEBHOOK_SECRET=
MOOLRE_SENDER_ID=FitPay

# Anthropic
ANTHROPIC_API_KEY=

# Shared secret for server-to-server calls to internal routes
# (/api/sms/send, /api/ai/*, /api/engine/progress). REQUIRED — without it those
# routes reject every call (fail closed) so SMS/AI will not fire. Use a long
# random value, e.g. `openssl rand -hex 32`. The pg_cron job that calls
# /api/ai/checkin must send it as the `x-internal-secret` header.
INTERNAL_API_SECRET=

# Config
NEXT_PUBLIC_APP_URL=
USE_SANDBOX=true
